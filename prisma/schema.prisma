// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id           String    @id @default(cuid())
    login        String?
    passwordHash String?
    email        String?   @unique
    rating       Int
    games        Game[]    @relation("games")
    WinnerGames  Game[]
}

enum GameStatus {
    idle
    inProgress
    gameOver
}

model Game {
    id         String     @id @default(cuid())
    name       String
    type       String
    field      String?
    status     GameStatus
    players    User[]     @relation("games")
    winner     User?      @relation(fields: [winnerId], references: [id])
    winnerId   String?
    gameOverAt String?
}
